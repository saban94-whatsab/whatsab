rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // User Validation
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500))
        && (data.lastSeen == null || data.lastSeen is timestamp)
        && (data.isTyping == null || data.isTyping is bool)
        && (data.isAdmin == null || data.isAdmin is bool)
        && (data.userCode == null || (data.userCode is string && data.userCode.size() <= 10));
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Restricted by filters usually, but for internal team it's fine to see colleagues
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming())
        && incoming().keys().hasAll(['uid', 'displayName']) && incoming().keys().size() >= 2;
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastSeen', 'isTyping', 'userCode'])
          || (existing().isAdmin == true && incoming().diff(existing()).affectedKeys().hasOnly(['isAdmin']))
        );
    }

    // Chat Validation
    function isValidChat(data) {
      return data.participants is list && data.participants.size() >= 1 && data.participants.size() <= 100
        && (data.lastMessage == null || (data.lastMessage is string && data.lastMessage.size() <= 1000))
        && (data.lastMessageTime == null || data.lastMessageTime is timestamp)
        && (data.name == null || (data.name is string && data.name.size() <= 100))
        && data.type in ['direct', 'group'];
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in existing().participants);
      allow create: if isSignedIn() && (request.auth.uid in incoming().participants) && isValidChat(incoming());
      allow update: if isSignedIn() && (request.auth.uid in existing().participants) && isValidChat(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageTime', 'participants', 'name', 'isTyping']);
    }

    // Message Validation
    function isValidMessage(data) {
      return data.chatId is string && isValidId(data.chatId)
        && data.senderId == request.auth.uid
        && data.text is string && data.text.size() <= 5000
        && data.type in ['text', 'image', 'file', 'system']
        && (data.fileUrl == null || (data.fileUrl is string && data.fileUrl.size() <= 1000))
        && (data.fileName == null || (data.fileName is string && data.fileName.size() <= 255))
        && data.createdAt == request.time;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      allow create: if isSignedIn() 
        && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
        && isValidMessage(incoming())
        && incoming().chatId == chatId;
      allow delete: if false; // Messages are immortal for compliance
    }

    // Stock Validation
    match /stock/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Simplified for internal app, Noaa updates this.
    }
  }
}

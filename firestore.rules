rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // User Validation
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
        && (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 1000))
        && (data.get('lastSeen', null) == null || data.lastSeen is timestamp)
        && (data.get('isTyping', null) == null || data.isTyping is bool)
        && (data.get('isAdmin', null) == null || data.isAdmin is bool)
        && (data.get('userCode', null) == null || (data.userCode is string && data.userCode.size() <= 10))
        && (data.get('email', null) == null || (data.email is string && data.email.size() <= 100))
        && (data.get('method', null) == null || (data.method is string && data.method.size() <= 20));
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming())
        && incoming().keys().hasAll(['uid', 'displayName']) && incoming().keys().size() >= 2;
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastSeen', 'isTyping', 'userCode', 'email', 'method'])
          || (existing().get('isAdmin', false) == true && incoming().diff(existing()).affectedKeys().hasOnly(['isAdmin']))
        );
    }

    // Chat Validation
    function isValidChat(data) {
      return data.participants is list && data.participants.size() >= 1 && data.participants.size() <= 100
        && (data.get('lastMessage', null) == null || (data.lastMessage is string && data.lastMessage.size() <= 1000))
        && (data.get('lastMessageTime', null) == null || data.lastMessageTime is timestamp)
        && (data.get('name', null) == null || (data.name is string && data.name.size() <= 100))
        && (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 1000))
        && data.type in ['direct', 'group'];
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (chatId == "main-group" || (exists(/databases/$(database)/documents/chats/$(chatId)) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants));
      allow create: if isSignedIn() && (request.auth.uid in incoming().participants) && isValidChat(incoming());
      allow update: if isSignedIn() && isValidChat(incoming())
        && (
          (request.auth.uid in (exists(/databases/$(database)/documents/chats/$(chatId)) ? get(/databases/$(database)/documents/chats/$(chatId)).data.participants : [])) // Already a member
          || (chatId == "main-group" && incoming().diff(existing()).affectedKeys().hasOnly(['participants']) && (request.auth.uid in incoming().participants)) // Joining main group
        )
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageTime', 'participants', 'name', 'isTyping', 'photoURL'])
        );
    }

    // Message Validation
    function isValidMessage(data) {
      return data.chatId is string && isValidId(data.chatId)
        && data.senderId == request.auth.uid
        && data.text is string && data.text.size() <= 6000
        && data.type in ['text', 'image', 'file', 'system', 'voice']
        && (data.get('fileUrl', null) == null || (data.fileUrl is string && data.fileUrl.size() <= 1000))
        && (data.get('fileName', null) == null || (data.fileName is string && data.fileName.size() <= 255))
        && data.createdAt == request.time;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      allow create: if isSignedIn() 
        && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
        && isValidMessage(incoming())
        && incoming().chatId == chatId;
      allow delete: if false; // Messages are immortal for compliance
    }

    // Stock Validation
    match /stock/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Simplified for internal app, Noaa updates this.
    }
  }
}
